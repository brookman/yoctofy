# SPDX fixup: filter runtime dependencies and add license information
#
# The `*-licenses.json` file generated by the `cargo-yocto` integration contains
# all dependencies, not just the runtime ones. In addition, license information
# is missing and marked as `NOASSERTION`.
#
# This script post-processes the SPDX output to address these issues. It:
#
# - Filters the dependency list to runtime dependencies only
# - Replaces `NOASSERTION` entries with proper license information
#
# The script uses a `${BPN}-licenses.json` file generated by Yoctify
# (https://github.com/brookman/yoctofy) as the authoritative license source and
# applies the data to the corresponding SPDX files.
#
# Requirements:
#
# - A license mapping file named `${BPN}-licenses.json`
# - The file must be located in the recipe directory


SPDX_LICENSE_MAPPING ?= "${THISDIR}/${BPN}-licenses.json"

SRC_URI += " file://${BPN}-licenses.json"

do_create_spdx[file-checksums] += "${SPDX_LICENSE_MAPPING}:True"

python do_create_spdx:append() {
    import json
    from pathlib import Path

    spdx_path = Path(d.getVar("SPDXDEPLOY")) / d.getVar("SSTATE_PKGARCH") / "recipes" / f"recipe-{d.getVar('PN')}.spdx.json"
    mapping_path = Path(d.getVar("WORKDIR")) / f"{d.getVar('BPN')}-licenses.json"

    if not spdx_path.exists() or not mapping_path.exists():
        bb.warn("SPDX fixup: missing file(s)")
        return

    with open(spdx_path) as f:
        spdx = json.load(f)
    with open(mapping_path) as f:
        license_mapping = json.load(f)

    allowed_urls = set(license_mapping.keys())
    kept_spdxids = set()
    new_packages = []

    for pkg in spdx.get('packages', []):
        spdxid = pkg.get('SPDXID', '')
        download_location = pkg.get('downloadLocation', '')
        pkg_name = pkg.get('name', '')

        is_recipe = spdxid.startswith('SPDXRef-Recipe-')
        is_main_source = pkg_name.endswith('-source-1')
        is_dep = download_location.startswith(('crate://', 'git+https://', 'git://'))

        if is_recipe or is_main_source:
            new_packages.append(pkg)
            kept_spdxids.add(spdxid)
        elif is_dep and download_location in allowed_urls:
            pkg['licenseDeclared'] = license_mapping[download_location]
            new_packages.append(pkg)
            kept_spdxids.add(spdxid)
        elif not is_dep:
            new_packages.append(pkg)
            kept_spdxids.add(spdxid)

    spdx['packages'] = new_packages
    spdx['relationships'] = [
        rel for rel in spdx.get('relationships', [])
        if (rel.get('spdxElementId') == 'SPDXRef-DOCUMENT' or rel.get('spdxElementId') in kept_spdxids)
        and (rel.get('relatedSpdxElement') == 'SPDXRef-DOCUMENT' or rel.get('relatedSpdxElement') in kept_spdxids)
    ]

    with open(spdx_path, 'w') as f:
        json.dump(spdx, f, sort_keys=True)

    bb.note(f"SPDX fixup: {len(new_packages)} packages, {len(spdx['relationships'])} relationships")
}
